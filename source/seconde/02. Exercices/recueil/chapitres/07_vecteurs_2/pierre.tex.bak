
\exo

\begin{enumerate}


\item Dans le repère $(O,\overrightarrow{i},\overrightarrow{j})$, lire les coordonnées des vecteurs $\overrightarrow{a}$ à $\overrightarrow{h}$.
\item Choisir trois de ces vecteurs et les écrire sous la forme $x\overrightarrow{i}+y\overrightarrow{j}$.
\item Représenter les vecteurs $\overrightarrow{u} \left( \begin{array}{c}
-3\\
4
\end{array} \right)$, $\overrightarrow{v} \left( \begin{array}{c}
0\\
5
\end{array} \right)$, $\overrightarrow{w} \left( \begin{array}{c}
-2\\
2
\end{array} \right)$.
\item Calculer les coordonnées des vecteurs :
\[
2\overrightarrow{a}\ ;\quad -3\overrightarrow{f}\ ;\quad \overrightarrow{c}+2\overrightarrow{h}\ ;\quad -\overrightarrow{d}+4\overrightarrow{b}.
\]

\end{enumerate}
