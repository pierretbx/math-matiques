\section*{Exercice VI}

\begin{tikzpicture}[scale=0.9,line cap=round,line join=round,>=triangle 45,x=1cm,y=1cm]
\begin{axis}[
x=1cm,y=0.5cm,
axis lines=middle,
ymajorgrids=true,
xmajorgrids=true,
xmin=-1.1708216394975663,
xmax=9.451846314003042,
ymin=-1.9724568113496113,
ymax=8.857955626248144,
xtick={-1,0,...,9},
ytick={0,2,...,8},]
\clip(-1.1708216394975663,-1.9724568113496113) rectangle (9.451846314003042,8.857955626248144);
\draw[line width=2pt,color=purple,smooth,samples=100,domain=-1.1708216394975663:9] plot(\x,{sin((3.141592653589793/4*(\x))*180/pi)/(\x)*10});
\begin{scriptsize}
\draw[color=purple] (8,2) node {$C_f$};
\end{scriptsize}
