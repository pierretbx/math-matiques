\section*{Exercice V}
\definecolor{qqwuqq}{rgb}{0,0.39215686274509803,0}
\begin{tikzpicture}[line cap=round,line join=round,>=triangle 45,x=1cm,y=1cm]
\begin{axis}[
x=1cm,y=1cm,
axis lines=middle,
ymajorgrids=true,
xmajorgrids=true,
xmin=-0.5830842383944765,
xmax=8.40014447492528,
ymin=-0.6408155466991156,
ymax=8.51809560560343,
xtick={0,1,...,8},
ytick={0,1,...,8},]
\clip(-0.5830842383944765,-0.6408155466991156) rectangle (8.40014447492528,8.51809560560343);
\draw[line width=2pt,color=qqwuqq,smooth,samples=100,domain=1:5.5] plot(\x,{((\x)-3)^(3)-3*((\x)-3)+2});
\begin{scriptsize}
\draw[color=qqwuqq] (5,2) node {$C_f$};
\end{scriptsize}
\end{axis}
\end{tikzpicture}

\begin{itemize}
\item[A)] Placer les points suivants:
$$A=(0;1) ;\; B=(1;0);\; C=(-4;1);\; D=(4;3);\; E=(4;0) ;$$
$$F=(5;2) ;\; G=(0;3) ;\; I=(5;4)$$
\item[B)] Déterminer à partir de la question 1) si les points appartiennent à $C_f$.
\item[C)] Faire une représentation graphique d'une fonction tel que $A\in C_f$ et $x_A=3$
\item[D)] Traduire graphiquement $f(2)=3$, inversement traduire en terme d'égalité de fonction $(8;9)\in C_f$.
\end{itemize}

\section*{Exercice V1}

\definecolor{qqqqff}{rgb}{0,0,1}

\begin{tikzpicture}[scale=0.85,line cap=round,line join=round,>=triangle 45,x=1cm,y=1cm]
\begin{axis}[
x=0.5cm,y=0.5cm,
axis lines=middle,
ymajorgrids=true,
xmajorgrids=true,
xmin=-7.192591830628359,
xmax=15.565669991302348,
ymin=-10.579069415623279,
ymax=6.82156679827874,
xtick={-6,-4,...,14},
ytick={-10,-8,...,6},]
\clip(-7.192591830628359,-10.579069415623279) rectangle (15.565669991302348,6.82156679827874);
\draw[line width=2pt,color=qqqqff,smooth,samples=100,domain=-5:14] plot(\x,{(((\x)+17.2)/10-2)^(2)*(((\x)+17.2)/10-3)*10+1});
\begin{scriptsize}
\draw[color=qqqqff] (14,1) node {$C_f$};
\end{scriptsize}
\end{axis}
\end{tikzpicture}

\begin{itemize}
\item[A)] Est-ce que l'image de 1 par $f$ est 0?
\item[B)] Est-ce que l'antécédant de 1 par $f$ est 0
\item[C)] L'image de 3 par $f$ est-elle négative ?
\item[D)] Est-ce que $-6\in D_f$? Déterminer $D_f$.
\item[E)] Les antécédants de 1 par $f$ sont-ils \{-6,3;0;5,7\}?
\item[F)] Est-ce que la fonction est croissante $[-6;4]$?
\item[G)] Est-ce que la fonction est décroissante sur [0;5]?
\item[H)] Les extrémas de $f$ sont-ils -0.9 et 3?
\end{itemize}

\section*{Exercice V2}
I] Faire une représentation graphique d'une fonction $f$ tel que:
\begin{itemize}
\item[a)] la fonction soit définit sur [-3;5].
\item[b)] croissante sur [-3;0].
\item[c)] décroissante sur [0;5].
\item[d)] l'image de 2 par $f$ est 4.\\

\end{itemize}



II] Faire une représentation graphique d'une fonction $f$ tel que:
\begin{itemize}
\item[a)] la fonction soit définie sur [0;10].
\item[b)] décroissante sur [9;10].
\item[c)] l'image de 3 par $f$ soit égale à 5.
\item[d)] 1 possède deux antécédents qui sont -2 et 5.
\end{itemize}


