\begin{itemize}
\item[A)] Donner deux nombres de départs différents $a$ et $b$ tel que $f(a)\geq 4$ et $f(b)\geq 4$.
\item[B)] Donner tous les nombres $c$ tel que $f(c)\leq 2$.
\item[C)] Donner deux nombres de départs différents $d$ et $e$ tel que $f(d) \leq 0$ et $f(e) < 0$.
\item[B)] Donner tous les nombres $x$ tel que $f(x) < 0$.
\end{itemize}


\section*{Exercice VII}

\begin{center}
\begin{tikzpicture}[scale=0.7]
   \tkzTabInit{$x$ / 1 , $f(x)$ / 2}{$0$, $3$, $5$ ,$7$}
   \tkzTabVar{-/ $-2$, +/ $2$, -/ $0$, +/ $3$ }
\end{tikzpicture}
\end{center}

Comparer, quand cela est possible:

\begin{itemize}
\item[A)] $f(0)$ et $f(4.5)$
\item[B)] $f(1)$ et $f(5)$
\item[C)] $f(1.5)$ et $f(7)$
\item[D)] $f(0.3)$ et $f(3)$
\end{itemize}


