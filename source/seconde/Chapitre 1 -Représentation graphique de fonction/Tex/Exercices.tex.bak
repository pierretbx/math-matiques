\begin{center}
\underline{\textbf{Fonction et courbe représentative}}
\end{center}
\section*{Exercice I}

\definecolor{qqwuqq}{rgb}{0,0.39215686274509803,0}
\begin{tikzpicture}[line cap=round,line join=round,>=triangle 45,x=1cm,y=1cm]
\begin{axis}[
x=1cm,y=1cm,
axis lines=middle,
ymajorgrids=true,
xmajorgrids=true,
xmin=-1.1494350490037846,
xmax=8.495961843022176,
ymin=-1.0061649840716078,
ymax=4.261083877355956,
xtick={-1,0,...,8},
ytick={-1,0,...,4},]
\clip(-1.1494350490037846,-1.0061649840716078) rectangle (8.495961843022176,4.261083877355956);
\draw[line width=2pt,color=qqwuqq,smooth,samples=100,domain=0:7] plot(\x,{((\x)-6.6)^(3)*0.01+2.9});
\begin{scriptsize}
\draw[color=qqwuqq] (7,2.5) node {$C_f$};
\end{scriptsize}
\end{axis}
\end{tikzpicture}


\begin{itemize}
\item[A)] Quel est l'ensemble de définition de cette fonction?
\item[B)] Calculer l'image de 1; 2; 0 et 7.
\item[C)] Est-il possible de calculer l'image de 8 par cette fonction? Justifiez.
\end{itemize}


\section*{Exercice II}
\definecolor{ffqqtt}{rgb}{1,0,0.2}
\begin{tikzpicture}[scale=0.9,line cap=round,line join=round,>=triangle 45,x=1cm,y=1cm]
\begin{axis}[
x=1cm,y=4cm,
axis lines=middle,
ymajorgrids=true,
xmajorgrids=true,
xmin=-0.866083596246753,
xmax=9.938937848850262,
ymin=-0.11748809433653769,
ymax=1.2453388040611781,
xtick={0,1,...,9},
ytick={0,0.1,...,1.2000000000000002},]
\clip(-0.866083596246753,-0.11748809433653769) rectangle (9.938937848850262,1.2453388040611781);
\draw[line width=2pt,color=ffqqtt,smooth,samples=100,domain=0:8] plot(\x,{sin((3.141592653589793/4*(\x))*180/pi)/2+0.5});
\begin{scriptsize}
\draw[color=ffqqtt] (8,0.8) node {$C_f$};
\end{scriptsize}
\end{axis}
\end{tikzpicture}

\begin{itemize}
\item[A)] Déterminer $D_f$.
\item[B)] Calculer l'image de 3; 2; 0 et 6.
\item[C)] Que remarque t-on pour les valeurs 0 et 8?
\item[D)] Existe t-il un autre nombre de $D_f$ différent de 0 et 8 tel que son image par cette fonction soit $0,5$.
\end{itemize}

