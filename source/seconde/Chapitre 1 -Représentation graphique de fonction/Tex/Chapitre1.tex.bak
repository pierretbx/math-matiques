\chapter{Fonctions et courbes reprÃĐsentatives}
\textit{C'est au XIV\up{ÃĻme} siÃĻcle que Nicolas Oresme a introduit la notion de fonction, il cherche Ã  comprendre des phÃĐnomÃĻnes physiques, notamment la chaleur, la vitesse et ÃĐtabli, Ã  l'aide d'une des premiÃĻres reprÃĐsentations graphiques, une relation entre le temps et la vitesse.}
% http://vivienfrederic.free.fr/QuelquesReperesHistoriquesLesfonctions.pdf




\section{DÃĐfinitions et notations}


\begin{defn}
Une fonction $f$, est un procÃĐdÃĐ qui, Ã  un nombre \underline{de dÃĐpart} lui associe un \underline{unique} nombre d'arrivÃĐ, appelÃĐ \underline{image}.

%Une fonction est la donnÃĐe d'un ensemble de nombre notÃĐ $D_f$, appelÃĐ ensemble de dÃĐfinition et d'un objet $f:x \rightarrow f(x)$ qui Ã  n'importe quel nombre $x$ de $D_f$ lui associe un \underline{unique} nombre notÃĐ $f(x)$, appelÃĐ image de $x$ par $f$.
\end{defn}

\underline{Exemple}: Soit Julien un individu de 35 ans, on peut faire la fonction ($f$) qui Ã  l'ÃĒge de Julien lui associe sa taille, si Ã  17 ans Julien mesure $1,75m$, on peut ÃĐcrire $f(17)=1,75$ ou encore  $f:17 \mapsto 1,75$.
 
\underline{Inversement}, si l'on a $f(25)=1,80 $ ou encore $f:25 \mapsto 1,80$, on peut traduire ceci par la phrase suivante: "Ã 25 ans, Julien mesurait 1,80m.". \\


On peut aussi faire la fonction ($g$) qui associe l'heure de la journÃĐe au pourcentage de la batterie d'un smartphone, si Ã  3h le tÃĐlÃĐphone indique 55\% de batterie on pourra ÃĐcrire $g(3)=55$ ou encore $g:3 \mapsto 55$.
\underline{Inversement}, si on lit $g(7)=100$, on peut traduire ceci par la phrase suivante: "Ã 7h la batterie du tÃĐlÃĐphone ÃĐtait rechargÃĐe au maximum de sa capacitÃĐ".

\begin{defn}
On appelle ensemble de dÃĐfinition de $f$, l'ensemble des nombres de dÃĐpart, que l'on notera $D_f$.
\vspace{4mm}

\end{defn}

\underline{Exemple}: Ici pour notre premier exemple $D_f$ serai $[0;35]$ et pour notre second exemple $[0;24]$.\\ \emph{Attention cependant Ã  la conversion temps-unitÃĐ}\\

%\underline{Exemple}: Soit ici $D_f=\mathbb{R}$ et $f:x \rightarrow 2x+3$ que l'on notera aussi $f(x)=2x+3$ qui est l'image de $x$ par $f$.

%\begin{defn}
%Quand un tel nombre $f(x)$ existe, on dit que $x$ est \underline{un} antÃĐcÃĐdent de $f(x)$, attention contrairement Ã  l'image, il n'y a \underline{pas nÃĐcÃĐssairement unicitÃĐ} de l'antÃĐcÃĐdent.
%\end{defn}

%\underline{Exemple}: Soit ici $D_f=\mathbb{R}$ et $f(x)=(x-2)(x-3)$ alors ici on $f(2)=0$ et $f(3)=0$ ainsi $3$ est \underline{un} antÃĐcÃĐdent de $0$ par $f$ et \underline{les} antÃĐcÃĐdents de $0$ par $f$ sont $2$ et $3$.


On peut donner de maniÃĻre ÃĐquivalente la dÃĐfinition d'une fonction avec des reprÃĐsentations graphiques, c'est ce que l'on ÃĐtudiera dans la suite de ce chapitre.

\newpage

\section{DÃĐfinition d'une fonction par reprÃĐsentation graphique}

\begin{defn}
Un point $A$ du plan est la donnÃĐe de deux nombres: son \underline{abscisse} notÃĐ $x_A$ et son \underline{ordonnÃĐe} $y_A$. Un point $A$ sera notÃĐ sous la forme suivante, $A=(x_A;y_A)$.
\end{defn}

Soit une fonction $f$ dÃĐfinie sur un ensemble $D_f$.

\begin{defn}

La courbe reprÃĐsentative de la fonction $f$, notÃĐe $C_f$,  est lâensemble des points de coordonnÃĐes $(x ; f(x))$, avec $x$ qui prend \emph{(une par une)} toutes les valeurs de l'ensemble $D_f$.

%est le nombre de dÃĐpart et $y$ l'image \textit{(le nombre d'arrivÃĐ)}, et oÃđ $x$ prend toutes les valeurs de lâensemble $D_f$. 

%On note parfois $C_f$, $\{y=f(x)\}$ que l'on peut traduire littÃĐralement par:  "$y$ est l'image du nombre de dÃĐpart $x$ par la fonction $f$." 

%Une fonction $f$ est la donnÃĐe d'une courbe qui se situera au dessus ou en dessous des nombres de $D_f$ reprÃĐsentÃĐ sur l'axe des abscisse, l'unique point au dessus ou en dessous d'un nombre de $D_f$ est appelÃĐ de ce nombre par la fonction $f$. 

%On placera les nombres de $D_f$ sur l'axe des abscisses,  l'unique po au dessus ou en dessous d'un nombre de $D_f$ est appelÃĐ image de ce nombre par la fonction $f$.

%$f:x \rightarrow f(x)$ qui Ã  n'importe quel nombre $x$ de $D_f$ lui associe un \underline{unique} nombre notÃĐ $f(x)$, appelÃĐ image de $x$ par $f$.
\end{defn}

%Pour des questions pratiques, on travaillera ici dans un %repÃĻre orthonormÃĐ.

%L'axe des abscisses reprÃĐsentera les ÃĐventuels nombres rÃĐels $D_f$ et l'axe des ordonnÃĐes reprÃĐsentera les ÃĐventuelles valeurs prises par la fonction $f$.


\underline{Exemple}: Voici une reprÃĐsentation graphique d'une fonction $f$ oÃđ $D_f$ est l'intervalle $[0;5]$.
\begin{center}
\begin{tikzpicture}
\begin{axis}[
xlabel=axe des abscisses,
ylabel=axe des ordonnÃĐes,
width=9cm,height=9cm,
axis lines=left,
scaled ticks=false,
]
\addplot [red,domain=0:5]{(-((x-3)^2)+9)/3};
