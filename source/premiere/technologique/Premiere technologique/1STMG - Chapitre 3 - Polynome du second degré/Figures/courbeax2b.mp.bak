prologue :=2;
input latexmp;
input repere;

beginfig(1);
repere(-3,4,2cm,-1.5,2.5,2cm);
path C_f;
vardef f(expr x)= (x**2)/2 -1 enddef;
C_f= courbefonc(f)(-3,3);
draw axes(1,1);
label.top("$x$", (3.8,0));
label.rt("$y$", (0,2.3));
draw C_f withpen pencircle scaled 1;
label("$y=\dfrac{1}{2} x^2-1$", (2,-0.5));
drawoptions(withcolor red);
marquepointcourbe(C_f,0);
label("$(0,b)$", (0.2,-1.1));
endfig;


beginfig(2);
repere(-2,3,2cm,-2.1,2.5,2cm);
path C_f;
vardef f(expr x)= -3*(x**2)+1.5 enddef;
C_f= courbefonc(f)(-1.1,1.1);
draw axes(1,1);
label.top("$x$", (2.8,0));
label.rt("$y$", (0,2.3));
draw C_f withpen pencircle scaled 1;
label("$y=-3x^2+\frac{3}{2}$", (1.2,0.5));
drawoptions(withcolor red);
marquepointcourbe(C_f,0);
label.lft("$(0,b)$", (0,1.6));
endfig;

beginfig(3);
repere(-3,3,2cm,-2.1,2.5,2cm);
path C_f;
vardef f(expr x)= 0.07*(x**2) enddef;
C_f= courbefonc(f)(-3,3);
draw axes(1,1);
label.top("$x$", (2.8,0));
label.rt("$y$", (0,2.3));
draw C_f withpen pencircle scaled 1;
label("$y=0,07x^2$", (1.2,0.5));
drawoptions(withcolor red);
marquepointcourbe(C_f,0);
label.lft("$(0,0)$", (0,0.1));
endfig;

beginfig(4);
repere(-3,3,2cm,-2.5,2.5,2cm);
path C_f;
vardef f(expr x)= 2(x**3) enddef;
C_f= courbefonc(f)(-1.08,1.08);
draw axes(1,1);
label.top("$x$", (2.8,0));
label.rt("$y$", (0,2.3));
draw C_f withpen pencircle scaled 1;
label("$y=2x^3$", (1.3,0.5));
draw quadrillage(1,1) dashed evenly;
drawoptions(withcolor red);
marquepointcourbe(C_f,0);
label.lft("$(0,0)$", (0,0.1));
endfig;

beginfig(5);
repere(-3,3,2cm,-2.5,2.5,2cm);
path C_f;
vardef f(expr x)= -0.1(x**3) enddef;
C_f= courbefonc(f)(-2.9,2.9);
draw axes(1,1);
label.top("$x$", (2.8,0));
label.rt("$y$", (0,2.3));
draw C_f withpen pencircle scaled 1;
label("$y=-\frac{1}{10}x^3$", (1.3,0.5));
draw quadrillage(1,1) dashed evenly;
drawoptions(withcolor red);
marquepointcourbe(C_f,0);
label.lft("$(0,0)$", (0,0.1));
endfig;
fin;

beginfig(6);
repere(-3,3,2cm,-1.5,2.5,2cm);
path C_f;
vardef f(expr x)= -0.1(x**3)+1 enddef;
C_f= courbefonc(f)(-2.5,2.9);
draw axes(1,1);
label.top("$x$", (2.8,0));
label.rt("$y$", (0,2.3));
draw C_f withpen pencircle scaled 1;
label("$y=-\frac{1}{10}x^3+1$", (1.3,1.5));
draw quadrillage(1,1) dashed evenly;
drawoptions(withcolor red);
marquepointcourbe(C_f,0);
label.lft("$(0,b)$", (0,1.2));
endfig;
fin;

beginfig(7);
repere(-3,3.6,2cm,-2.4,2.6,2cm);
path C_f;
vardef f(expr x)=  -0.2*(x-3)*(x+2)*x enddef;
C_f= courbefonc(f)(-2.8,3.6);
draw axey(1,1);
draw axex.llft(1,1);
label.top("$x$", (3.4,0));
label.rt("$y$", (0,2.3));
draw C_f withpen pencircle scaled 1;
label("$y=-\frac{2}{10}x(x-3)(x+2)$", (1.5,2));
draw quadrillage(1,1) dashed evenly;
drawoptions(withcolor red);
marquepointcourbe(C_f,0,-2,3);
%label.lft("$(0,b)$", (0,1.2));
endfig;

beginfig(8);
repere(-2,5,2cm,-1,8,2cm);
path C_f;
vardef f(expr x)=  ((-1)*(x**2))+(4*x)+3 enddef;
C_f= courbefonc(f)(-0.7,4.7);
draw axey(1,1);
draw axex(1,1);
label.top("$x$", (4.8,0));
label.rt("$y$", (0,7.8));
draw C_f withpen pencircle scaled 1;
label("$y=-x^2+4x+3$", (4,7.1));
draw quadrillage(1,1) dashed evenly;
drawoptions(withcolor red);
marquepointcourbe(C_f,2);
draw projetex((2,7))--(2,7)--projetey((2,7));
%label.lft("$(0,b)$", (0,1.2));
endfig;

beginfig(9);
repere(-1.5,2.5,2cm,-1.3,1.5,2cm);
path C_f;
vardef f(expr x)=  (0.5)*(x+1)*(x-1)*(x-2) enddef;
C_f= courbefonc(f)(-1.3,2.5);
draw axey(1,1);
draw axex(1,1);
label.top("$x$", (2.3,0));
label.rt("$y$", (0,1.3));
draw C_f withpen pencircle scaled 0.8 withcolor pourpre;
%label("$y=-x^2+4x+3$", (4,7.1));
draw quadrillage(1,1) dashed evenly;
%drawoptions(withcolor red);
%marquepointcourbe(C_f,2);
%draw projetex((2,7))--(2,7)--projetey((2,7));
%label.lft("$(0,b)$", (0,1.2));
endfig;

beginfig(10);
repere(-2,2,2cm,-2.1,2.1,2cm);
path C_f;
vardef f(expr x)=  x**3-3*x enddef;
C_f= courbefonc(f)(-2,2);
draw axey(1,1);
draw axex(1,1);
label.top("$x$", (1.95,0));
label.rt("$y$", (0,1.9));
draw C_f withpen pencircle scaled 0.8 withcolor pourpre;
%label("$y=-x^2+4x+3$", (4,7.1));
draw quadrillage(1,1) dashed evenly;
%drawoptions(withcolor red);
%marquepointcourbe(C_f,2);
%draw projetex((2,7))--(2,7)--projetey((2,7));
%label.lft("$(0,b)$", (0,1.2));
endfig;

beginfig(11);
repere(-2,2,2cm,-2.2,2.2,2cm);
path C_f;
path C_g;
vardef f(expr x)=(-1.5)*(x**2) enddef;
vardef g(expr x)=3*(x**2)-2 enddef;
C_f= courbefonc(f)(-1.3,1.3);
C_g= courbefonc(g)(-1.2,1.2);
draw axey(0.5,0.5);
draw axex(1,1);
label.top("$x$", (1.95,0));
label.rt("$y$", (0,1.9));
draw C_f withpen pencircle scaled 0.8 withcolor pourpre dashed evenly;
label.top("$\mathcal{C}_f$", (1.2,1));
label.rt("$\mathcal{C}_g$", (-1,-1.75)) withcolor pourpre;
draw C_g withpen pencircle scaled 0.9;
%label("$y=-x^2+4x+3$", (4,7.1));
draw quadrillage(1,1) dashed evenly;
%drawoptions(withcolor red);
%marquepointcourbe(C_f,2);
%draw projetex((2,7))--(2,7)--projetey((2,7));
%label.lft("$(0,b)$", (0,1.2));
endfig;

beginfig(12);
repere(-2,4.5,2cm,-5,5,1cm);
path C_f;
path C_g;
path C_h;
vardef f(expr x)=(x+1)*(x-3) enddef;
vardef g(expr x)=x*(x-4) enddef;
vardef h(expr x)=(-1)*(x+1)*(x-3) enddef;
C_f= courbefonc(f)(-2,4);
C_g= courbefonc(g)(-1,4);
C_h= courbefonc(h)(-2,4);
draw axey(0.5,1);
draw axex(1,1);
label.top("$x$", (4.2,0));
label.rt("$y$", (0.1,4.5));
draw C_f withpen pencircle scaled 0.8 withcolor pourpre dashed evenly;
label.top("$\mathcal{C}_1$", (-0.6,4));
label.rt("$\mathcal{C}_2$", (-1,-1.75)) withcolor pourpre;
label.rt("$\mathcal{C}_3$", (2.1,3)) withcolor marine;
draw C_g withpen pencircle scaled 2 dashed withdots;
draw C_h withpen pencircle scaled 0.9 withcolor marine;
%label("$y=-x^2+4x+3$", (4,7.1));
draw quadrillage(1,1) dashed evenly;
%drawoptions(withcolor red);
%marquepointcourbe(C_f,2);
%draw projetex((2,7))--(2,7)--projetey((2,7));
%label.lft("$(0,b)$", (0,1.2));
endfig;

fin;
end.