\newpage
\section{Représentations graphiques}

\subsection{Définition d'une courbe}
\begin{defn}
La courbe représentative de la fonction $f$, notée $C_f$,  est l’ensemble des points de coordonnées $(x ; f(x))$, avec $x$ qui prend \emph{(une par une)} toutes les valeurs de l'ensemble $D_f$. \\
 
Autrement dit, $$ C_f= \{ (x ; f(x))\; /  \; x\in D_f \} $$
\end{defn}

\subsection{Représentation graphique d'une fonction $x \mapsto u(x+a)+b$}
\begin{prop}
Soit $u$ une fonction et $v$ la fonction définie par $v(x)=u(x+a)+b$.

Dans un repère $\oij$, on appelle $\calc_{u}$ et $\calc_{v}$ les courbes représentatives des fonctions $u$ et $v$.

$\calc_{v}$ est l'image de $\calc_{u}$ par la translation de vecteur $-a\vect{i}+b\vect{j}$, autrement dit le vecteur de coordonnées $\cp{-a}{b}$.
\end{prop}
\begin{center}
\includegraphics{Figures/FiguresFonctionsCours.1}
\end{center}

%\ifthenelse{\value{version}>0}{\newpage}{}
\begin{demo}
Soient $M(x;y)$ et $M'(x-a;y+b)$.

\[M'\in \calc_{v} \Leftrightarrow y+b=v(x-a) \Leftrightarrow y+b=u(x-a+a)+b \Leftrightarrow y=u(x) \Leftrightarrow M \in \calc_{v}\]
\end{demo}


\subsection{Représentation graphique d'une fonction $\lambda u$}
\begin{prop}
Soit $u$ une fonction et $v$ la fonction $\lambda u$
Dans un repère $\oij$, on appelle $\calc_{u}$ et $\calc_{v}$ les courbes représentatives des fonctions $u$ et $v$.
Si $M$ est le point de $\calc_{u}$ d'abscisse $x$ alors on obtient le point d'abscisse $x$ de $\calc_{v}$ en multipliant l'ordonnée de $M$ par $\lambda$.
\end{prop}

\begin{minipage}[c]{0.3\linewidth}
\begin{center}
\includegraphics[scale=0.9]{Figures/FiguresFonctionsCours.2}
\end{center}
\end{minipage}
\hfill
\begin{minipage}[c]{0.3\linewidth}
\begin{center}
