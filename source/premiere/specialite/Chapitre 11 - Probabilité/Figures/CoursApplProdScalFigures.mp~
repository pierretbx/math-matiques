input geometriesyr15;
input latexmp;

vardef nomme@#(suffix p)=
  MarquePoint(p);
  label.@#(textext("$" & str p & "$"),p);
enddef;

figure(-u,-u,4.35u,3.5u);
pair A,B,M,I;
A=(0,0);
B=u*(4,0);
M=u*(1,3);
nomme.llft(A);
nomme.lrt(B);
nomme.top(M);
trace triangle(A,B,M);
I=milieu(A,B);
nomme.bot(I);
draw M--I;
draw codesegments(A,I,I,B,2);
fin

figure(-u,-u,5u,5u);
pair A,B,C,a,b,c;
B=(0,0);
C=u*(4,0);
A=u*(1,3);
nomme.top(A);
nomme.llft(B);
nomme.lrt(C);
trace triangle(A,B,C);
a=iso(B,C);
b=iso(A,C);
c=iso(A,B);
nomme.bot(a);
nomme.ulft(c);
nomme.urt(b);
draw codeangle.bot(B,A,C,0,btex $\widehat{A}$ etex);
draw codeangle.urt(C,B,A,0,btex $\widehat{B}$ etex);
draw codeangle.ulft(A,C,B,0,btex $\widehat{C}$ etex);
marque_a:=17;
draw marqueangle(C,B,A,0);
draw marqueangle(A,C,B,0);
marque_a:=14;
draw marqueangle(A,C,B,0);
fin;

figure(-u,-u,5u,5u);
pair A,B,C,a,b,c,H;
B=(0,0);
C=u*(4,0);
A=u*(1,3);
H=projection(C,A,B);
nomme.top(A);
nomme.llft(B);
nomme.lrt(C);
nomme.ulft(H);
trace C--H;
trace triangle(A,B,C);
trace codeperp(C,H,A,5);
a=iso(B,C);
b=iso(A,C);
c=iso(A,B);
nomme.bot(a);
nomme.ulft(c);
nomme.urt(b);
draw codeangle.bot(B,A,C,0,btex $\widehat{A}$ etex);
fin;

end