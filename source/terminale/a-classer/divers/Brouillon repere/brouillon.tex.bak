draw axex(1,1);
draw axey(10,20);
draw quadrillage(1,10) dashed evenly;
setquad(0,9,0,300);
draw cadre;
pair A,B,C,D,E,F;
A=(1,70);B=(2,90);C=(3,115);D=(4,140);E=(5,170);F=(6,220);
marquepoints(A,B,C,D,E,F);
path Cc;
vardef c(expr x)=29x+32.7 enddef;
Cc= courbefonc(c)();
pair H;
H=(8,250);
