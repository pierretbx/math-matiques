input repere;

beginfig(1);
repere(-0.5,9,1.5cm,-10,310,0.5mm);
draw axex(1,1);
draw axey(10,20);
draw quadrillage(1,10) dashed evenly;
draw cadre;
pair A,B,C,D,E,F;
A=(1,70);B=(2,90);C=(3,115);D=(4,140);E=(5,170);F=(6,220);
marquepoints(A,B,C,D,E,F);
fin;
endfig;



beginfig(2);
repere(-0.5,9,1.5cm,-10,310,0.5mm);
draw axex(1,1);
draw axey(10,20);
draw quadrillage(1,10) dashed evenly;
setquad(0,9,0,300);
draw cadre;
pair A,B,C,D,E,F;
A=(1,70);B=(2,90);C=(3,115);D=(4,140);E=(5,170);F=(6,220);
marquepoints(A,B,C,D,E,F);
path Cm;
vardef m(expr x)=28.1x+35.1 enddef;
Cm= courbefonc(m)();
pair G;
G=(6,250);
label("$\mathcal{D}_1: y=28,3x+35,1$",G) withcolor bleu;
draw Cm withpen pencircle scaled 1 withcolor bleu;
pair Z,Y,X;
X=(2,91.7);Y=(5,176.7);Z=(3.5,134.2);
marquepoints(X,Y,Z) withcolor olive;
label.ulft("$G_1$",X);
label.ulft("$G_2$",Y);
label.ulft("$G$",Z);
fin;
endfig;

beginfig(3);
repere(-0.5,9,1.5cm,-10,200,0.8mm);
draw axex(1,1);
draw axey(10,20);
draw cadre;
pair A,B,C,D,E,F;
A=(1,80);B=(2,60);C=(3,100);D=(4,120);E=(5,100);F=(6,150);
marquepoints(A,B,C,D,E,F);
path G;
vardef d(expr x)=14*x+52.66 enddef;
G= courbefonc(d)();
label("$\mathcal{D}_2: y=14x+52,66$",(7,130)) withcolor pourpre;
draw G withpen pencircle scaled 1 withcolor pourpre;
draw projetex(D)--D--projetey(D) dashed evenly;
draw A--(1,d(1)) dashed evenly;
draw B--(2,d(2)) dashed evenly;
draw C--(3,d(3)) dashed evenly;
%draw D--(4,d(4)) dashed evenly;
draw E--(5,d(5)) dashed evenly;
draw F--(6,d(6)) dashed evenly;
label.urt("$x_4$",(4,0));
label.urt("$y_4$",(0,120));
label.urt("$M_4$",D);
pair Q;
Q=(4,d(4));
marquepoint(Q) withcolor pourpre;
label.lrt("$Q_4$",Q) withcolor pourpre;
draw Q--projetey(Q) dashed evenly withcolor pourpre;
label.urt("$ax_4+b$",projetey(Q)) withcolor pourpre;
fin;
endfig;

beginfig(4);
repere(-0.5,9,1.5cm,-10,310,0.5mm);
draw axex(1,1);
draw axey(10,20);
draw quadrillage(1,10) dashed evenly;
setquad(0,9,0,300);
draw cadre;
pair A,B,C,D,E,F;
A=(1,70);B=(2,90);C=(3,115);D=(4,140);E=(5,170);F=(6,220);
marquepoints(A,B,C,D,E,F);
path Cc;
vardef c(expr x)=29x+32.7 enddef;
Cc= courbefonc(c)();
pair H;
H=(6,250);
label("$\mathcal{D}_2: y=29x+32,7$",H) withcolor red;
draw Cc withpen pencircle scaled 1 withcolor red;
fin;
endfig;

beginfig(5);
repere(-0.5,9,1.5cm,-10,310,0.5mm);
draw axex(1,1);
draw axey(10,20);
draw quadrillage(1,10) dashed evenly;
setquad(0,9,0,300);
draw cadre;
pair A,B,C,D,E,F;
A=(1,70);B=(2,90);C=(3,115);D=(4,140);E=(5,170);F=(6,220);
marquepoints(A,B,C,D,E,F);
path Ce;
vardef e(expr x)=57.111*((1.251)**x) enddef;
Ce= courbefonc(e)();
pair I;
I=(7.5,290);
label("$\mathcal{C}_e$",I) withcolor violet;
draw Ce withpen pencircle scaled 1 withcolor violet;
fin;
endfig;

end.