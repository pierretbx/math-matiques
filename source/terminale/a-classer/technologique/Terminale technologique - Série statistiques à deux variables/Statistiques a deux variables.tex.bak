\begin{corrige}
On doit avoir $ \left\lbrace
\begin{array}{l}
\dfrac{8,2+7,4+x+6,1+9}{5}=7,5\\
\dfrac{15+12,1+16,3+y+12}{5}=12,6
\end{array}
\right.$\\
$\Leftrightarrow \left\lbrace
\begin{array}{l}
\dfrac{30,7+x}{5}=7,5\\
\dfrac{55,4+y}{5}=12,6
\end{array}
\right. \Leftrightarrow \left\lbrace
\begin{array}{l}
30,7+x=37,5\\
55,4+y=63
\end{array}
\right.\Leftrightarrow \left\lbrace
\begin{array}{l}
x=6,8\\
y=7,6
\end{array}
\right.$
\end{corrige}

