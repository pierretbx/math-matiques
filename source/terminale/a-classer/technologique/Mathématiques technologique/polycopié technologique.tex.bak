  child {node {$\bar{B}$}
    child {node {$\bar{S}$} edge from parent node[below]{$\cdots$}}
    child {node {$S$} edge from parent node[above]{$\cdots$}}
    edge from parent node[below]{$\cdots$}}
  child{node {$B$}
    child {node {$\bar{S}$} edge from parent node[below]{$\cdots$}}
