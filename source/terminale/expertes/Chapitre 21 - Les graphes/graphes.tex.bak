$s_1$ &  & $s_2$ \\
$s_3$ &  & $s_4$
\end{psmatrix}
\psset{shortput=nab}
\nccircle[angleA=0]{1,1}{0.5cm}^{$a$}
\ncarc[arcangle=15]{1,1}{1,3}^{$b$}
\ncarc[arcangle=15]{1,3}{1,1}^{$c$}
\ncline{1,1}{2,1}^{$d$}
\ncline{1,3}{2,1}^{$e$}
\end{pspicture*}

\end{exemple}


\begin{rem}
 La position des sommets et la longueur ou l'allure des arêtes n'ont aucune importance. 
\end{rem}



