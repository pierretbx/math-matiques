\chapter{Lois de probabilités continues}

\section{Généralités sur les lois de probabilités continues}

\begin{rem}
 On considère un univers $I$ de la forme $[a;b]$ où $a$ et $b$ sont deux réels tels que $a<b$ ou de la forme $[a;+\infty[$ avec $a$ réel. 
On notera :
\begin{itemize}
 \item[$\bullet$] $\int_{I}f(x)\dx=\int_a^bf (x)\dx$ dans le premier cas ;
  \item[$\bullet$] $\int_{I}f(x)\dx=\lim_{b\rightarrow +\infty}\int_{a}^{b}f(x)\dx$ dans le deuxième cas.
\end{itemize}
\end{rem}


\begin{defn}
Avec les notations précédentes :
\begin{itemize}
\item[$\bullet$] On appelle \emph{densité de probabilité} sur $I$, toute fonction $f$ continue et positive telle que 
$$\int_{I}f(x)\dx=1$$
\item[$\bullet$] On dit qu'une variable aléatoire $X$ à valeurs dans $I$ suit une loi de probabilité de densité $f$ sur $I$ si pour tout intervalle $J$ inclus dans I : 
$$P(X\in J)=\int_{J}f(x)\dx$$
\end{itemize}
Une telle variable aléatoire est dite continue sur $I$.
\end{defn}

\begin{prop}
 Soit $X$ une variable aléatoire suivant une loi de probabilité continuede densité $f$ sur $I$.
\begin{itemize}
 \item[$\bullet$] $P(X\in I)=1$ ;
\item[$\bullet$] Pour tout réel $u$, $P(X=u)=\int_{u}^{u}f(x)\dx=0$ ;
\item[$\bullet$] $P(X\in[a;b])=P(X\in]a;b])=P(X\in[a;b[)=P(X\in]a;b[)$ et $P(X\leq a))=P(X<a)$ pour tous les réels $a$ et $b$ avec $a<b$.
\end{itemize}

\end{prop}

\begin{rem}
 On note $P(a\leq x\leq b)=P(X\in [a;b])$.
\end{rem}

\begin{defn}
Soit $X$ un variable aléatoire réelle suivant une loi de probabilité continue de densité $f$ définie sur un intervalle $I$, alors 

$$E(X)= \int_{I}xf(x)\dx$$
\end{defn}


\section{Loi uniforme}

\begin{defn}
 Soit $[a;b]$ un intervalle avec $a$ et $b$ réels. On appelle \emph{loi uniforme} sur $[a;b]$ , la loi de probabilité dont la densité $f$ est :
$$f(x)=\frac{1}{b-a}$$ pour tout réel $x\in[a;b]$.
\end{defn}

\begin{demo}
 On a $f\geq 0$ et on vérifie que $\int_{a}^{b}f(x)\dx=1$.
\end{demo}


\begin{prop}
 Soit $X$ une variable aléatoire suivant la loi uniforme sur $[a;b]$. ALors l'espérance $E(X)$ de $X$ est :
$$E(X)=\int_{a}^{b}xf(x)\dx=\frac{a+b}{2}$$
\end{prop}

\begin{demo}
$$\int_{a}^{b}xf(x)\dx=\int_{a}^{b}x\dfrac{1}{b-a}\dx = \cro{\dfrac{x^2}{2(b-a)}}_a^b$$
$$= \dfrac{b^2-a^2}{2(b-a)}=\dfrac{(b-a)(b+a)}{2(b-a)}=\dfrac{b+a}{2}$$
\end{demo}

\begin{exemple}
 La fonction \texttt{Alea()} du tableur donne des valeurs suivants la loi uniforme sur $[0;1]$.
\end{exemple}


\section{Loi exponentielle}

\begin{defn}
 Soit $\lambda$ un réel strictement positif. On appelle \emph{loi exponentielle} de paramètre $\lambda$ la loi de probabilité dont la densité $f$ est définie par :
$$f(x)=\lambda e^{-\lambda x}$$
pour tout réel $x\in [0;+\infty[$.
\end{defn}

\begin{demo}
 On a $f\geq 0$ et $\lim_{b\rightarrow +\infty}\int_{0}^{b}f(x)\dx=1$. Effectivement
 $\int_{0}^{b}f(x)\dx=\int_{0}^{b}\lambda e^{-\lambda x} \dx= \cro{-e^{-\lambda x}}_0^b=  \cro{e^{-\lambda x}}_b^0=1-e^{-\lambda b}$
\end{demo}


\begin{prop}
 L'espérance d'une variable aléatoire $X$ qui suit la loi exponentielle de paramètre $p$ est $$E(X)=\frac{1}{\lambda}$$
\end{prop}

\begin{demo}
On cherche ici à calculer $\int_{0}^{+ \infty}xf(x)\dx =  \lim_{b\rightarrow +\infty}\int_{0}^{b}xf(x)\dx$, cherchons donc une primitive de $xf(x)=x\lambda e^{-\lambda x}$ de la forme $(ax+b)e^{-\lambda x}$ .\\

On sait que $((ax+b)e^{-\lambda x})'=ae^{-\lambda x}-\lambda(ax+b)e^{-\lambda x}=(a-a\lambda x-b\lambda)e^{-\lambda x}$ qui doit être égale à $xf(x)=x\lambda e^{-\lambda x}$ d'où $-a\lambda x=x\lambda$ et $a-b\lambda=0$, on déduit que $a=-1$ et $b=\dfrac{-1}{\lambda}$

Ainsi une primitive de $xf(x)$ est $(-x-\dfrac{1}{\lambda})e^{-\lambda x}$. Donc $\int_{0}^{b}xf(x)\dx=\cro{(-x-\dfrac{-1}{\lambda})e^{-\lambda x}}_0^b=\cro{(x+\dfrac{1}{\lambda})e^{-\lambda x}}_b^0=\dfrac{1}{\lambda}-(b+\dfrac{1}{\lambda})e^{-\lambda b}$. \\

d'où $\int_{0}^{+ \infty}xf(x)\dx =  \lim_{b\rightarrow +\infty}\int_{0}^{b}xf(x)\dx=\dfrac{1}{\lambda}$
 

\end{demo}

